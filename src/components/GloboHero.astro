---
---

<section class="globe-hero" id="inicio">
  <div class="hero-sticky">

    <!-- Globo Three.js -->
    <div class="globe-stage" id="globe-container">
      <canvas id="globe-canvas"></canvas>
    </div>

    <!-- Texto editorial -->
    <div class="hero-copy">
      <h1 class="hero-title">
        <span class="word-main" data-reveal="title">MUNBOLDT</span>
        <span class="word-year" data-reveal="year">2027</span>
      </h1>
      <p class="hero-tagline" data-reveal="year" data-i18n="hero.tagline">Construyendo puentes, no muros</p>
      <span class="hero-eyebrow" data-reveal="year">Colegio Humboldt Puebla</span>
      <div class="hero-divider" data-reveal="year"></div>
      <p class="hero-sub" data-reveal="year" data-i18n="hero.subtitle">Modelo de Naciones Unidas — Edición 2027</p>
      <a href="#comites" class="hero-cta" data-reveal="cta" data-i18n="hero.cta">Explorar Comités</a>
    </div>

  </div>
</section>

<style>
  .globe-hero {
    position: relative;
    height: 200vh;
    background: var(--white);
  }
  .hero-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .hero-sticky::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--gray-mid);
    z-index: 3;
  }

  /* ── Globe stage (centered, shifts right + scales as you scroll) ──
     No clipping mask — the globe (and its atmosphere/rings, which extend
     beyond the sphere itself) must float freely on the white background
     without being cut off by a circular container. */
  .globe-stage {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(620px, 64vw);
    height: min(620px, 64vw);
    transform: translate(-50%, -50%);
    z-index: 1;
  }
  #globe-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ── Editorial copy — 2rem rhythm between every block ── */
  .hero-copy {
    position: relative;
    z-index: 2;
    padding: 0 3rem 0 6rem;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: block;
    opacity: 0;
  }
  .hero-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.01em;
    display: flex;
    flex-direction: column;
    gap: 0.2em;
  }
  .word-main {
    color: var(--navy);
    opacity: 0;
  }
  .word-year {
    color: var(--gold);
    opacity: 0;
  }
  .hero-tagline {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-weight: 600;
    font-size: clamp(1.4rem, 2.2vw, 1.8rem);
    color: var(--navy);
    line-height: 1.5;
    opacity: 0;
  }
  .hero-divider {
    width: 40px;
    height: 2px;
    background: var(--gold);
    opacity: 0;
  }
  .hero-sub {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0;
  }
  .hero-cta {
    display: inline-block;
    background: var(--navy);
    color: #fff;
    padding: 0.85rem 2.25rem;
    border-radius: 3px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background 0.25s, transform 0.25s;
    align-self: flex-start;
    /* Revealed late in the scroll sequence — see `ctaProgress` below */
    opacity: 0;
  }
  .hero-cta:hover {
    background: var(--un-blue);
    transform: translateY(-2px);
  }

  /* ── Responsive: disable scroll-jacking, show static hero ── */
  @media (max-width: 900px) {
    .globe-hero { height: auto; }
    .hero-sticky {
      position: relative;
      height: auto;
      flex-direction: column;
      align-items: stretch;
      padding: 6.5rem 0 2.5rem;
      overflow: visible;
    }
    .globe-stage {
      position: relative;
      top: auto;
      left: auto;
      width: min(420px, 78vw);
      height: min(420px, 78vw);
      margin: 0 auto 2rem;
      transform: none !important;
      opacity: 1 !important;
    }
    .hero-copy {
      position: relative;
      padding: 0 2rem;
      max-width: 100%;
    }
    .hero-eyebrow,
    .word-main,
    .word-year,
    .hero-tagline,
    .hero-divider,
    .hero-sub,
    .hero-cta {
      opacity: 1 !important;
      transform: none !important;
    }
  }
  @media (max-width: 480px) {
    .hero-copy { padding: 0 1.5rem; }
    .hero-title { font-size: 2.6rem; }
  }
</style>

<script>
  import * as THREE from 'three';
  import { FontLoader } from 'three/examples/jsm/loaders/FontLoader.js';
  import { TextGeometry } from 'three/examples/jsm/geometries/TextGeometry.js';

  const container = document.getElementById('globe-container') as HTMLElement;
  const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
  if (!container || !canvas) throw new Error('Globe elements not found');

  let renderer: THREE.WebGLRenderer;
  let camera: THREE.PerspectiveCamera;
  let scene: THREE.Scene;
  let earth: THREE.Mesh;
  let ring1: THREE.Mesh, ring2: THREE.Mesh;
  let letterGroup: THREE.Group, pueblaPin: THREE.Mesh;
  let raf: number;
  // Procedural gold matcap used by the hero letters — created once the font
  // (and thus the letter meshes) load, repainted each frame for the shimmer.
  let goldMatcap: THREE.CanvasTexture | undefined;

  // ── Hero-letter orbit → banner state ────────────────────────────────
  // Populated by the FontLoader callback below: each entry tracks a letter
  // mesh plus the angle/radius it started its orbit at, so animate() can
  // compute its current orbital position without a parent group.
  const heroLetters: { mesh: THREE.Mesh; initAngle: number; orbitRadius: number; charIndex: number }[] = [];
  // Accumulated orbital angle (radians), added to each letter's initAngle.
  // Replaces letterGroup.rotation.y now that letters are detached from it.
  let globalOrbitAngle = 0;
  // Mirrors the `progress` value computed in updateHeroProgress() (0→1 over
  // the hero's scroll range) so animate()'s RAF loop can read it.
  let scrollProgress = 0;

  // ── Intro auto-scroll ────────────────────────────────────────────────
  // Once the orbiting name has had a moment to read, the page scrolls
  // itself down through the hero's scroll range. Because the whole hero is
  // already driven off scroll position, this single programmatic glide
  // flies the 3D letters into the banner, slides the globe right and
  // reveals the editorial copy in one continuous, cinematic hand-off from
  // the planet scene into the page — instead of the text spinning in place
  // forever. It runs once, desktop-only, is skipped under
  // prefers-reduced-motion, and cancels the instant the user takes over.
  const AUTO_SCROLL_DELAY    = 2600;  // ms to let the name sweep/read first
  const AUTO_SCROLL_DURATION = 2200;  // ms length of the glide itself
  const AUTO_SCROLL_TARGET   = 0.82;  // fraction of hero scroll range to land on
                                      // (banner fully formed at ~0.80; globe
                                      // stays crisp — its fade starts at 0.84)
  let autoScrollTimer = 0;
  let autoScrollRaf = 0;
  let autoScrollDone = false;

  const clamp = (v: number, min: number, max: number) => Math.min(Math.max(v, min), max);
  const ease = (v: number, start: number, end: number) => clamp((v - start) / (end - start), 0, 1);

  // ── Diagonal tilt of the letter orbit ─────────────────────────────────
  // The reference render shows the text band running diagonally (~22°),
  // ascending left→right across the globe's face. That look is a screen-
  // space ROLL of the orbit plane about the view (z) axis — not a tilt
  // about the x-axis, which would render as a flat "∩" arch (the ring's
  // ellipse bulging at the center with both ends level), not a diagonal.
  // More negative TILT = steeper diagonal (band crosses the globe straighter,
  // reading less like a pronounced arch).
  const TILT = -0.52; // ~30°
  const cosTilt = Math.cos(TILT);
  const sinTilt = Math.sin(TILT);

  // ── Banner layout for the detached "MUNBOLDT 2027" letters ───────────
  // Indices follow "MUNBOLDT 2027" (13 chars): 0-7 = MUNBOLDT, 8 = space
  // (no mesh, see FontLoader callback), 9-12 = 2027. Line 1 sits slightly
  // above center, line 2 slightly below, both left-aligned in the scene.
  // Letters shrink to BANNER_SCALE during the transition so the larger
  // orbit glyphs (size 0.42) fit the left panel at this spacing.
  const BANNER_SCALE = 0.52;
  function getBannerTarget(i: number): THREE.Vector3 {
    const LS1 = 0.23;   // line-1 spacing (MUNBOLDT)
    const LS2 = 0.30;   // line-2 spacing (2027, airier)
    const START_X = -1.05;
    const BZ = 0.15;
    if (i < 8)  return new THREE.Vector3(START_X + i * LS1, 0.28, BZ);
    if (i === 8) return new THREE.Vector3(-9, 0, BZ); // space: no mesh uses this
    return new THREE.Vector3(START_X + (i - 9) * LS2, -0.07, BZ);
  }

  // ── Procedural gold matcap for the hero letters ──────────────────────
  // Paints a circular "gold sphere" lighting map onto a canvas — no external
  // image needed. `offsetX` (a fraction of `size`) shifts the key-light and
  // secondary specular highlights horizontally, used by the shimmer
  // animation in animate() to slide the highlight across the gold over time.
  function paintGoldMatcap(ctx: CanvasRenderingContext2D, size: number, offsetX = 0) {
    const h = size / 2;

    ctx.clearRect(0, 0, size, size);
    ctx.save();
    ctx.beginPath();
    ctx.arc(h, h, h - 1, 0, Math.PI * 2);
    ctx.clip();

    // Base shadow
    ctx.fillStyle = '#2A1500';
    ctx.fillRect(0, 0, size, size);

    // Main key-light gradient (top-left highlight → dark shadow)
    const main = ctx.createRadialGradient(h * 0.62 + offsetX * size, h * 0.44, 0, h, h, h);
    main.addColorStop(0.00, '#FFFCD5'); // hot specular (near white-gold)
    main.addColorStop(0.07, '#FFE030'); // bright yellow-gold
    main.addColorStop(0.20, '#D4930C'); // rich amber gold
    main.addColorStop(0.40, '#A36900'); // deep mid-gold
    main.addColorStop(0.62, '#5C3600'); // shadowed gold
    main.addColorStop(0.84, '#2C1900'); // deep shadow
    main.addColorStop(1.00, '#180C00'); // edge
    ctx.fillStyle = main;
    ctx.fillRect(0, 0, size, size);

    // Warm fill bounce light from bottom-right
    const fill = ctx.createRadialGradient(h * 1.7, h * 1.65, 0, h, h, h * 1.1);
    fill.addColorStop(0.00, 'rgba(255, 150, 0, 0.60)');
    fill.addColorStop(0.40, 'rgba(190,  95, 0, 0.25)');
    fill.addColorStop(1.00, 'rgba(0, 0, 0, 0)');
    ctx.fillStyle = fill;
    ctx.fillRect(0, 0, size, size);

    // Warm rim light from right edge
    const rim = ctx.createRadialGradient(size * 0.90, h * 0.75, 0, size * 0.80, h * 0.80, size * 0.55);
    rim.addColorStop(0.00, 'rgba(255, 215, 70, 0.75)');
    rim.addColorStop(0.35, 'rgba(200, 140,  0, 0.35)');
    rim.addColorStop(1.00, 'rgba(0, 0, 0, 0)');
    ctx.fillStyle = rim;
    ctx.fillRect(0, 0, size, size);

    // Tight secondary specular
    const sp = ctx.createRadialGradient(
      h * 0.52 + offsetX * size, h * 0.38, 0,
      h * 0.52 + offsetX * size, h * 0.38, h * 0.11
    );
    sp.addColorStop(0.00, 'rgba(255, 255, 250, 0.96)');
    sp.addColorStop(0.55, 'rgba(255, 248, 200, 0.50)');
    sp.addColorStop(1.00, 'rgba(255, 240, 150, 0)');
    ctx.fillStyle = sp;
    ctx.fillRect(0, 0, size, size);

    ctx.restore();
  }

  function createGoldMatcap(size = 512): THREE.CanvasTexture {
    const canvas = document.createElement('canvas');
    canvas.width = canvas.height = size;
    const ctx = canvas.getContext('2d')!;
    paintGoldMatcap(ctx, size, 0);

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function buildScene(w: number, h: number) {
    // Renderer
    renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    // Pure white backdrop matching the page background — the reference
    // render floats the globe on white, no dark card behind it.
    renderer.setClearColor(0xFFFFFF, 1);
    renderer.sortObjects = true;

    // Scene & camera
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0xFFFFFF);
    camera = new THREE.PerspectiveCamera(42, w / h, 0.1, 100);
    camera.position.set(0, 0.4, 6.2);

    // Lights
    const ambient = new THREE.AmbientLight(0xffffff, 1.2); // boosted for MeshStandardMaterial metalness
    scene.add(ambient);
    const sun = new THREE.DirectionalLight(0xfff5e0, 2.0);
    sun.position.set(5, 3, 4);
    scene.add(sun);
    const fill = new THREE.DirectionalLight(0x3399ff, 0.4);
    fill.position.set(-4, -2, -2);
    scene.add(fill);
    // Atmospheric blue point light — sits near the globe centre for a soft
    // inner-glow effect that reads as scattered light through the atmosphere
    const atmPoint = new THREE.PointLight(0x4488ff, 0.8, 10);
    scene.add(atmPoint);
    // Gold rim light — placed behind and to the left so the globe's silhouette
    // picks up a warm halo that separates it from the white background
    const rimLight = new THREE.DirectionalLight(0xb8a96a, 0.3);
    rimLight.position.set(-5, 0, -6);
    scene.add(rimLight);

    // ── Atmosphere fresnel shells ─────────────────────────────────────
    // Two cyan rim-glow shells around the globe (radii relative to the
    // globe's radius of 2: 1.08× and 1.20×). Added in this exact order —
    // inner shell BEFORE the earth, outer shell AFTER — for stable
    // transparency sorting.
    //
    // Blending deviates from the usual AdditiveBlending recipe because the
    // backdrop is pure WHITE: additive output clamps to white and is
    // literally invisible over a white background, so the glow is encoded
    // in the ALPHA channel with normal blending instead. Both shells are
    // BackSide so the visible fragments form an annulus between the globe's
    // silhouette and the shell's edge; alpha is driven by -normal·view,
    // which is maximal at the globe's limb and reaches exactly 0 at the
    // shell's silhouette — a smooth fade-out with no hard edge ring.
    const atmoVert = `
      varying vec3 vNormal;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position,1.0);
      }
    `;

    // Inner shell: tight, intense cyan band hugging the globe's edge.
    // The alpha ramp maps the back-face normal's z across the visible
    // annulus — with the camera 6.2 units from a 2.16 shell, perspective
    // puts n·z ≈ -0.06 at the globe's limb (peak alpha) and n·z ≈ +0.35
    // (= 2.16/6.2) at the shell's own silhouette (alpha exactly 0), so the
    // glow fades out smoothly with no hard edge ring.
    const atmoInner = new THREE.Mesh(
      new THREE.SphereGeometry(2.16, 64, 64),
      new THREE.ShaderMaterial({
        vertexShader: atmoVert,
        fragmentShader: `
          varying vec3 vNormal;
          void main() {
            float d = dot(vNormal, vec3(0.0, 0.0, 1.0));
            float i = pow(clamp((0.35 - d) / 0.41, 0.0, 1.0), 2.0);
            gl_FragColor = vec4(0.10, 0.72, 1.00, i * 0.9);
          }
        `,
        side: THREE.BackSide,
        transparent: true,
        depthWrite: false,
      })
    );
    scene.add(atmoInner); // ← BEFORE the globe

    // ── Earth sphere — day/night texture blend ────────────────────────
    // A fixed sun direction lights one hemisphere with the day map and
    // fades the opposite one into the night map (city lights, brightened
    // ×1.8). vNormal carries the model rotation, so the terminator stays
    // fixed in space while the surface spins beneath it. The camera never
    // rotates, so view space ≈ world space for sunDir.
    //
    // No .colorSpace is set on either texture: raw ShaderMaterial output
    // skips three's colorspace_fragment conversion, so sRGB texels must
    // pass through unconverted to display correctly (tagging them SRGB
    // would hardware-decode to linear and render washed out).
    //
    // /earth-night.jpg does NOT exist in public/ (despite the spec), and
    // adding asset files is out of scope — so the night map streams from
    // the same threejs.org host that already serves the letter font above.
    const textureLoader = new THREE.TextureLoader();
    const earthDay = textureLoader.load(
      '/earth-blue-marble.jpg',
      undefined,
      undefined,
      (err) => { console.error('[GloboHero] Failed to load day texture:', err); }
    );
    const earthNight = textureLoader.load(
      'https://threejs.org/examples/textures/planets/earth_lights_2048.png',
      undefined,
      undefined,
      (err) => { console.error('[GloboHero] Failed to load night texture:', err); }
    );

    const earthGeo = new THREE.SphereGeometry(2, 72, 72);
    const earthMat = new THREE.ShaderMaterial({
      uniforms: {
        dayTex:   { value: earthDay },
        nightTex: { value: earthNight },
        sunDir:   { value: new THREE.Vector3(5, 3, 5).normalize() },
      },
      vertexShader: `
        varying vec2 vUv;
        varying vec3 vNormal;
        void main() {
          vUv = uv;
          vNormal = normalize(normalMatrix * normal);
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position,1.0);
        }
      `,
      fragmentShader: `
        uniform sampler2D dayTex;
        uniform sampler2D nightTex;
        uniform vec3 sunDir;
        varying vec2 vUv;
        varying vec3 vNormal;
        void main() {
          float sun = dot(vNormal, sunDir);
          float blend = smoothstep(-0.15, 0.40, sun);
          // ×2.2 on the day map replaces the lighting boost the previous
          // MeshPhongMaterial got from the scene lights (ambient 1.2 +
          // directional 2.0) — a raw ShaderMaterial is unlit, and the
          // blue-marble texture's raw texels render too dark/dull without
          // it (bumped from 1.8 so the lit hemisphere reads vivid like the
          // reference). Night keeps its 1.8 so the dark side isn't blown out.
          vec4 day   = texture2D(dayTex,   vUv) * 2.2;
          vec4 night = texture2D(nightTex, vUv) * 1.8;
          gl_FragColor = mix(night, day, blend);
        }
      `,
    });
    earth = new THREE.Mesh(earthGeo, earthMat);
    // 23.5° axial tilt. Euler order ZYX so the spin (rotation.y, applied
    // first) happens about the globe's own axis and the tilt (rotation.z)
    // then leans the whole spinning globe — with the default XYZ order the
    // tilted pole would precess around the vertical instead.
    earth.rotation.order = 'ZYX';
    earth.rotation.z = 23.5 * Math.PI / 180;
    scene.add(earth); // ← globe second

    // Outer shell: soft halo fading into the white background. Radius
    // pulled in to 2.28 (from 2.40) so the cyan halo reads narrower and
    // more subtle, not a wide prominent ring.
    // BackSide (not FrontSide as a dark-background recipe would use): on
    // white, a FrontSide fresnel peaks exactly at the shell's silhouette
    // and cuts off there — a visible hard-edged circle. Perspective-
    // corrected alpha ramp: for the 2.28 shell seen from 6.2 units the
    // silhouette sits at n·z ≈ +0.368 (= 2.28/6.2, alpha 0) and the globe's
    // limb at n·z ≈ -0.15 (alpha ~1), so the glow fades out with no hard edge.
    const atmoOuter = new THREE.Mesh(
      new THREE.SphereGeometry(2.28, 64, 64),
      new THREE.ShaderMaterial({
        vertexShader: atmoVert,
        fragmentShader: `
          varying vec3 vNormal;
          void main() {
            float d = dot(vNormal, vec3(0.0, 0.0, 1.0));
            float i = pow(clamp((0.368 - d) / 0.52, 0.0, 1.0), 2.5);
            gl_FragColor = vec4(0.08, 0.65, 1.00, i * 0.35);
          }
        `,
        side: THREE.BackSide,
        transparent: true,
        depthWrite: false,
      })
    );
    scene.add(atmoOuter); // ← AFTER the globe

    // ── Orbital rings — two thin beige great-circle lines crossing at
    // very different angles, static, per the reference render. Radii are
    // the reference proportions (1.44× / 1.48× globe radius) × radius 2.
    const ringMat = new THREE.MeshBasicMaterial({
      color: 0xD4C8A0,
      transparent: true,
      opacity: 0.45,
      side: THREE.DoubleSide,
    });

    ring1 = new THREE.Mesh(
      new THREE.TorusGeometry(2.88, 0.0056, 2, 120), ringMat
    );
    ring1.rotation.x = Math.PI / 2 + 0.15;
    ring1.rotation.z = 0.08;
    scene.add(ring1);

    ring2 = new THREE.Mesh(
      new THREE.TorusGeometry(2.96, 0.0044, 2, 120),
      ringMat.clone()
    );
    (ring2.material as THREE.MeshBasicMaterial).opacity = 0.28;
    ring2.rotation.x = Math.PI / 2 + 0.95;
    ring2.rotation.z = 0.35;
    scene.add(ring2);

    // ── 3D extruded letter ring (legacy group, kept empty) ────────────────
    // Each character of "MUNBOLDT 2027" is placed on a tilted circle at
    // radius 2.4, oriented to face radially outward — but is
    // added directly to `scene` and tracked in `heroLetters` (see FontLoader
    // callback below) so it can detach from its orbit and fly into the
    // banner headline independently. This group stays empty; it's kept so
    // nothing else that references `letterGroup` needs to change.
    letterGroup = new THREE.Group();
    scene.add(letterGroup);

    // A minimal 4×2 equirectangular DataTexture gives MeshStandardMaterial
    // something to reflect so metalness actually looks metallic instead of
    // flat/dark.  Sky-blue top pixels + warm-grey bottom pixels approximate
    // a simple outdoor environment without any external asset.
    try {
      const pmrem    = new THREE.PMREMGenerator(renderer);
      const envPx    = new Uint8Array([
        220,235,255,255,  220,235,255,255,  210,225,255,255,  220,235,255,255,
        200,195,185,255,  205,200,190,255,  200,195,185,255,  210,205,195,255,
      ]);
      const envTex   = new THREE.DataTexture(envPx, 4, 2, THREE.RGBAFormat);
      envTex.mapping = THREE.EquirectangularReflectionMapping;
      envTex.needsUpdate = true;
      scene.environment = pmrem.fromEquirectangular(envTex).texture;
      pmrem.dispose();
      envTex.dispose();
    } catch (e) {
      console.warn('[GloboHero] PMREMGenerator unavailable — metallic letters will appear flat:', e);
    }

    const fontLoader = new FontLoader();
    fontLoader.load(
      'https://threejs.org/examples/fonts/droid/droid_serif_bold.typeface.json',
      (font) => {
        const label  = 'MUNBOLDT 2027';
        const total  = label.length; // 13 — space keeps its angle slot
        const orbitR = 2.40;         // 1.20× globe radius — letters hug the globe per the reference render

        // Procedural gold matcap — bakes a fixed "polished gold sphere"
        // lighting look into a runtime canvas texture (see
        // paintGoldMatcap/createGoldMatcap above), so the letters read as
        // gold from any angle independent of scene lights/environment maps.
        // DoubleSide so the bevelled back faces also pick up the matcap as
        // letters rotate during the orbit → banner transition.
        //
        // No `scale.x = -1` here: the glyph mirroring/reading-order issue
        // fixed in commit 29693bd was a reversed letter SEQUENCE, not a
        // per-glyph mirror, and it was fixed via the `(total-1-i)` angle
        // index above — each letter's geometry is already unmirrored. Adding
        // scale.x = -1 now would flip every glyph (and its bevel normals)
        // and reintroduce that bug.
        goldMatcap = createGoldMatcap(512);
        const letterMaterial = new THREE.MeshMatcapMaterial({
          matcap: goldMatcap,
          side:   THREE.DoubleSide,
        });

        label.split('').forEach((char, i) => {
          if (char === ' ') return; // angle slot reserved, no mesh for space
          const geo = new TextGeometry(char, {
            font,
            size:           0.42,
            depth:          0.16,
            curveSegments:  12,
            bevelEnabled:   true,
            bevelThickness: 0.018,
            bevelSize:      0.007,
            bevelSegments:  5,
          });

          // Centre each letter on its own X and Y axes so the rotation pivot
          // is at the letter's visual midpoint rather than its baseline-left corner
          geo.computeBoundingBox();
          const bb = geo.boundingBox!;
          geo.translate(
            -(bb.max.x - bb.min.x) / 2,
            -(bb.max.y - bb.min.y) / 2,
            0
          );

          // Compress the full 360° distribution into a ~166° arc so all 13
          // letter-slots cluster on the camera-facing (z>0) hemisphere,
          // reading as a continuous word instead of scattered letters.
          //
          // The slot order is REVERSED (total-1-i instead of i): with the
          // position/rotation formulas below, increasing angle moves a
          // letter from the camera's right side toward its left side. Using
          // `i` directly therefore placed "M" on the right and "7" on the
          // left — the word read backwards ("7202 TDLOBNUM"). Reversing the
          // index keeps every individual glyph correctly oriented (each
          // letter's own face still reads normally) while putting "M" on
          // the left and "7" on the right, so "MUNBOLDT 2027" reads
          // correctly left-to-right.
          const angle = ((total - 1 - i) * (2 * Math.PI / total)) * 0.5;
          const mesh  = new THREE.Mesh(geo, letterMaterial);

          // Place on the orbit circle rolled by TILT about the view axis
          // (diagonal band, ascending left→right — see TILT above). The
          // flat circle point (flatX, 0, flatZ) rolled by -TILT about z:
          // x' = x·cos(-TILT) = x·cosTilt, y' = x·sin(-TILT) = -x·sinTilt.
          const flatX = orbitR * Math.cos(angle);
          const flatZ = orbitR * Math.sin(angle);
          mesh.position.set(flatX * cosTilt, -flatX * sinTilt, flatZ);
          // Euler order ZYX: yaw (rotation.y, applied first) faces the
          // letter radially outward, then rotation.z rolls it with the
          // tilted band so its baseline follows the diagonal.
          mesh.rotation.order = 'ZYX';
          // -angle rotates to the right arc position; +PI/2 tilts the face
          // outward so the front of each letter points away from globe centre
          mesh.rotation.y = -angle + Math.PI / 2;
          mesh.rotation.z = -TILT;

          scene.add(mesh);
          heroLetters.push({ mesh, initAngle: angle, orbitRadius: orbitR, charIndex: i });
        });

        // Letters are on screen — arm the cinematic intro auto-scroll.
        if (!autoScrollDone && !autoScrollTimer) {
          autoScrollTimer = window.setTimeout(startIntroAutoScroll, AUTO_SCROLL_DELAY);
        }
      },
      undefined,
      (err) => { console.error('[GloboHero] Failed to load font:', err); }
    );

    // ── Puebla, México pin — lat 19.0414 °N, lon -98.2063 °W
    // Converted to sphere-surface XYZ using the standard geographic formula.
    // The pin and its spike are children of `earth` so they rotate in lockstep
    // with the texture — no manual sync needed.
    const pinLat = 19.0414 * Math.PI / 180;
    const pinLon = -98.2063 * Math.PI / 180;
    const gr = 2; // globe radius
    const ppx = gr * Math.cos(pinLat) * Math.cos(pinLon);
    const ppy = gr * Math.sin(pinLat);
    // Negative z: Three.js SphereGeometry maps ~90°W to the +Z face (toward
    // camera), so the correct formula for the western hemisphere is z = -r·cos·sin.
    // Without the negative the pin lands on the opposite side of the globe (Asia).
    const ppz = -gr * Math.cos(pinLat) * Math.sin(pinLon);

    const pinMat = new THREE.MeshPhongMaterial({
      color: 0xb8a96a,
      emissive: new THREE.Color(0xb8a96a),
      emissiveIntensity: 0.7,
      shininess: 80,
    });
    // Glowing gold sphere at the pin location
    pueblaPin = new THREE.Mesh(new THREE.SphereGeometry(0.02, 10, 10), pinMat);
    pueblaPin.position.set(ppx, ppy, ppz);
    earth.add(pueblaPin);

    // Thin spike rising from the pin, aligned with the sphere's outward normal
    const pinPos  = new THREE.Vector3(ppx, ppy, ppz);
    const pinNorm = pinPos.clone().normalize();
    const spikeLen = 0.18;
    const spike = new THREE.Mesh(
      new THREE.CylinderGeometry(0.004, 0.004, spikeLen, 4),
      pinMat
    );
    spike.position.copy(pinPos).addScaledVector(pinNorm, spikeLen * 0.5);
    spike.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), pinNorm);
    earth.add(spike);
  }

  function animate() {
    raf = requestAnimationFrame(animate);
    // Earth spins on its axis (its 23.5° z-tilt is constant — ZYX Euler
    // order means this y-spin stays about the globe's own tilted axis).
    // The rings stay static: their two crossing angles are part of the
    // reference composition, set once at creation.
    earth.rotation.y += 0.0025;
    // ── Orbit → banner transition ────────────────────────────────────
    // The orbit decelerates to a stop over the first ~2/3 of the scroll
    // range, then each letter eases from its orbital position into its
    // slot in the "MUNBOLDT 2027" banner on the left.
    //
    // globalOrbitAngle accumulates +ORBIT_SPEED (not -ORBIT_SPEED) because
    // worldAngle = initAngle + globalOrbitAngle must reproduce the exact
    // motion of the previous `letterGroup.rotation.y -= 0.0025`: rotating a
    // group by rotY maps a child's local angle to a world angle of
    // (localAngle - rotY), so a -0.0025/frame group rotation is equivalent
    // to worldAngle increasing by +0.0025/frame. Accumulating with `-=`
    // here would reverse the orbit direction and the letter order verified
    // in commit 29693bd.
    //
    // Bumped 0.0025 → 0.008 so the name sweeps with more energy before the
    // intro auto-scroll (below) decelerates it into the banner.
    const ORBIT_SPEED = 0.008;
    globalOrbitAngle += ORBIT_SPEED * (1 - Math.min(scrollProgress * 1.5, 1));

    const rawT = clamp((scrollProgress - 0.05) / 0.75, 0, 1);
    const bannerEase = rawT < 0.5 ? 2 * rawT * rawT : -1 + (4 - 2 * rawT) * rawT;

    heroLetters.forEach(({ mesh, initAngle, orbitRadius, charIndex }) => {
      const worldAngle = initAngle + globalOrbitAngle;
      // Non-negated x/z — matches the verified-correct static formula in
      // the FontLoader callback (orbitR*cos, orbitR*sin). Negating would
      // flip the letters to the globe's far side and reverse their reading
      // order. The flat circle point is then rolled by -TILT about the
      // view axis for the diagonal band (same roll as the static placement).
      const flatX = orbitRadius * Math.cos(worldAngle);
      const flatZ = orbitRadius * Math.sin(worldAngle);
      const orbitPos = new THREE.Vector3(flatX * cosTilt, -flatX * sinTilt, flatZ);
      const bannerPos = getBannerTarget(charIndex);
      mesh.position.lerpVectors(orbitPos, bannerPos, bannerEase);

      // Yaw and roll both ease to 0 so banner letters sit flat and level.
      const orbitRotY = -worldAngle + Math.PI / 2;
      mesh.rotation.y = orbitRotY * (1 - bannerEase);
      mesh.rotation.z = -TILT * (1 - bannerEase);

      // Shrink toward BANNER_SCALE so the size-0.42 orbit glyphs fit the
      // banner spacing. Lerped from +1, not -1: this codebase never applied
      // the scale.x = -1 "mirror fix" (the 29693bd reading-order fix was an
      // angle-index reversal; glyph geometry was never mirrored), so a
      // negative scale here would mirror every glyph.
      const s = THREE.MathUtils.lerp(1.0, BANNER_SCALE, bannerEase);
      mesh.scale.set(s, s, s);
    });

    // ── Gold matcap shimmer ──────────────────────────────────────────
    // MeshMatcapMaterial samples its matcap using a UV derived from the
    // view-space surface normal (see three's meshmatcap fragment shader),
    // not the texture's own UV/offset/repeat — so animating
    // `goldMatcap.offset.x` would have no visual effect. Instead we repaint
    // the canvas each frame with the key-light highlight shifted slightly,
    // then flag the texture for re-upload.
    if (goldMatcap) {
      const shimmer = Math.sin(Date.now() * 0.00025) * 0.025;
      const matcapCanvas = goldMatcap.image as HTMLCanvasElement;
      paintGoldMatcap(matcapCanvas.getContext('2d')!, matcapCanvas.width, shimmer);
      goldMatcap.needsUpdate = true;
    }

    // Puebla pin pulses from 1× to 2× and back via a sine wave
    pueblaPin.scale.setScalar(1.5 + 0.5 * Math.sin(Date.now() * 0.003));
    renderer.render(scene, camera);
  }

  // Dispose any previous instance of this hero before starting a new one.
  // (Astro/Vite can re-execute this module — e.g. on HMR or client-side
  // navigation — and an orphaned render loop + ResizeObserver from a stale
  // instance would otherwise keep running invisibly and fight the new one,
  // which is exactly what made the rings appear "frozen" mid-session.)
  const INSTANCE_KEY = '__munboldtGlobeHero';
  const w = window as unknown as Record<string, { dispose: () => void } | undefined>;
  w[INSTANCE_KEY]?.dispose();

  let ro: ResizeObserver;

  // Init with ResizeObserver for correct dimensions
  ro = new ResizeObserver((entries) => {
    const { width, height } = entries[0].contentRect;
    if (width < 10 || height < 10) return;
    if (!renderer) {
      buildScene(width, height);
      animate();
    } else {
      renderer.setSize(width, height);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    }
  });
  ro.observe(container);

  w[INSTANCE_KEY] = {
    dispose() {
      if (raf) cancelAnimationFrame(raf);
      cancelAutoScroll();
      ro.disconnect();
      renderer?.dispose();
    },
  };

  /* ───────────────────────────────────────────────
     Scroll storytelling — Apple-style scroll-scrub.
     The hero is 200vh tall and pinned via `position:
     sticky`. As the user scrolls through that range we
     compute a 0→1 progress value and drive every reveal
     stage + the globe's position/scale directly off it:

       0%   → only the globe (30% larger), centered, full screen, navbar hidden
       33%  → globe glides right & settles to its resting scale ·
              "MUNBOLDT" fades in from the left · navbar fades in
       66%  → "2027" (gold), tagline, eyebrow, divider & sub-line appear
       70-85% → "Explorar Comités" button fades in last
       100% → globe fades out
  ─────────────────────────────────────────────── */
  const heroEl = document.querySelector('.globe-hero') as HTMLElement | null;
  const navbarEl = document.getElementById('navbar') as HTMLElement | null;
  const globeStage = document.getElementById('globe-container') as HTMLElement | null;
  const heroTitleEl = document.querySelector('.hero-title') as HTMLElement | null;

  function reveal(stage: string, value: number, slide: 'left' | 'up') {
    document.querySelectorAll<HTMLElement>(`[data-reveal="${stage}"]`).forEach((el) => {
      el.style.opacity = String(value);
      el.style.transform = slide === 'left'
        ? `translateX(${(1 - value) * -42}px)`
        : `translateY(${(1 - value) * 16}px)`;
    });
  }

  function isDesktop() { return window.innerWidth > 900; }

  function updateHeroProgress() {
    if (!heroEl) return;

    if (!isDesktop()) {
      // Static mobile hero — everything visible, navbar always shown,
      // globe at its natural (un-scaled) resting size. The 3D letters never
      // leave their orbit (scrollProgress stays 0), so the flat title stays put.
      scrollProgress = 0;
      reveal('title', 1, 'left');
      reveal('year', 1, 'up');
      if (heroTitleEl) heroTitleEl.style.opacity = '1';
      if (navbarEl) {
        navbarEl.style.opacity = '1';
        navbarEl.style.transform = 'none';
        navbarEl.style.pointerEvents = 'auto';
      }
      if (globeStage) { globeStage.style.opacity = '1'; globeStage.style.transform = 'none'; }
      return;
    }

    const rect = heroEl.getBoundingClientRect();
    const scrollRange = heroEl.offsetHeight - window.innerHeight;
    const progress = scrollRange > 0 ? clamp(-rect.top / scrollRange, 0, 1) : 0;
    scrollProgress = progress;

    // ── Stage 1 · ~33%: navbar fades in, globe slides right and settles
    // from its oversized entrance scale down to its resting size, "MUNBOLDT" appears
    const navProgress   = ease(progress, 0.10, 0.34);
    const titleProgress = ease(progress, 0.18, 0.40);
    const globeShift    = ease(progress, 0.18, 0.42);
    const globeSettle   = ease(progress, 0.00, 0.30);

    // ── Stage 2 · ~66%: "2027" + tagline + eyebrow + divider + sub-line
    const yearProgress = ease(progress, 0.50, 0.72);

    // ── Stage 3 · ~70-80%: "Explorar Comités" button fades in late, once
    // the reader has absorbed the title/tagline/sub-line above it
    const ctaProgress = ease(progress, 0.70, 0.85);

    // ── Stage 4 · 100%: globe fades out
    const globeFadeOut = ease(progress, 0.84, 1.0);

    if (navbarEl) {
      navbarEl.style.opacity = String(navProgress);
      navbarEl.style.transform = `translateY(${(1 - navProgress) * -14}px)`;
      navbarEl.style.pointerEvents = navProgress > 0.4 ? 'auto' : 'none';
    }

    reveal('title', titleProgress, 'left');
    reveal('year', yearProgress, 'up');
    reveal('cta', ctaProgress, 'up');

    // ── 3D banner takeover ── once the orbiting letters begin flying into
    // the "MUNBOLDT 2027" banner (see animate()), hide the flat HTML title
    // so the two don't overlap; it's only visible near the very top of the hero.
    if (heroTitleEl) {
      heroTitleEl.style.transition = 'opacity 0.3s';
      heroTitleEl.style.opacity = progress < 0.1 ? '1' : '0';
    }

    if (globeStage) {
      const shiftVw = globeShift * 24; // glides from center toward the right
      // Loads 30% larger (scale 1.3) and eases down to its resting size
      // (scale 1.0) as the user begins scrolling — a soft "settle-in".
      const scale = 1.3 - 0.3 * globeSettle;
      globeStage.style.transform = `translate(calc(-50% + ${shiftVw}vw), -50%) scale(${scale})`;
      globeStage.style.opacity = String(1 - globeFadeOut);
    }
  }

  // ── Intro auto-scroll implementation ──────────────────────────────────
  // Real user input cancels the glide immediately. A programmatic
  // `window.scrollTo` only emits `scroll` events (never wheel/touch/key),
  // so these listeners fire exclusively on genuine user intent — they
  // never trip on the glide's own scrolling.
  function onUserScrollIntent() { cancelAutoScroll(); }

  function cancelAutoScroll() {
    autoScrollDone = true;
    if (autoScrollTimer) { clearTimeout(autoScrollTimer); autoScrollTimer = 0; }
    if (autoScrollRaf)   { cancelAnimationFrame(autoScrollRaf); autoScrollRaf = 0; }
    window.removeEventListener('wheel', onUserScrollIntent);
    window.removeEventListener('touchstart', onUserScrollIntent);
    window.removeEventListener('keydown', onUserScrollIntent);
  }

  function startIntroAutoScroll() {
    autoScrollTimer = 0;
    if (autoScrollDone || !heroEl || !isDesktop()) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.scrollY > 10) return; // user already moved — don't hijack

    const scrollRange = heroEl.offsetHeight - window.innerHeight;
    if (scrollRange <= 0) return;

    const startY  = window.scrollY;
    const targetY = scrollRange * AUTO_SCROLL_TARGET;
    const t0 = performance.now();
    // Cubic ease-in-out: soft launch out of the orbit, gentle landing on the banner
    const easeIO = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

    window.addEventListener('wheel', onUserScrollIntent, { passive: true });
    window.addEventListener('touchstart', onUserScrollIntent, { passive: true });
    window.addEventListener('keydown', onUserScrollIntent);

    const stepScroll = (now: number) => {
      if (autoScrollDone) return;
      const t = Math.min((now - t0) / AUTO_SCROLL_DURATION, 1);
      window.scrollTo(0, startY + (targetY - startY) * easeIO(t));
      updateHeroProgress(); // keep the scene in lock-step with the glide this frame
      if (t < 1) {
        autoScrollRaf = requestAnimationFrame(stepScroll);
      } else {
        autoScrollRaf = 0;
        cancelAutoScroll(); // marks done + tears down listeners
      }
    };
    autoScrollRaf = requestAnimationFrame(stepScroll);
  }

  window.addEventListener('scroll', updateHeroProgress, { passive: true });
  window.addEventListener('resize', updateHeroProgress);
  updateHeroProgress();
</script>
