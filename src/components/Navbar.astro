      <li><a href="/#registro"   data-i18n="nav.registro">Registro</a></li>
      <li><a href="/#contacto"   data-i18n="nav.contacto">Contacto</a></li>
    </ul>

    <!-- Right -->
    <div class="nav-right">
      <div class="lang-selector" id="langSelector">
        <button class="lang-btn active" data-lang="es">ES</button>
        <button class="lang-btn" data-lang="de">DE</button>
        <button class="lang-btn" data-lang="en">EN</button>
      </div>
      <button class="nav-toggle" id="menuToggle" aria-label="Menú">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobileMenu" style="display:none">
    <ul>
      <li><a href="/"            data-i18n="nav.inicio">Inicio</a></li>
      <li><a href="/#comites"    data-i18n="nav.comites">Comités</a></li>
      <li><a href="/preparacion" data-i18n="nav.preparacion">Preparación</a></li>
      <li><a href="/#registro"   data-i18n="nav.registro">Registro</a></li>
      <li><a href="/#contacto"   data-i18n="nav.contacto">Contacto</a></li>
    </ul>
    <div class="lang-selector">
      <button class="lang-btn active" data-lang="es">ES</button>
      <button class="lang-btn" data-lang="de">DE</button>
      <button class="lang-btn" data-lang="en">EN</button>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background: var(--navy);
    z-index: 1000;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    opacity: 0; /* revealed by the hero's scroll-storytelling script */
    transition: box-shadow 0.3s;
  }
  .navbar.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.25); }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-humboldt {
    height: 30px;
    width: auto;
    object-fit: contain;
    background: #fff;
    border-radius: 4px;
    padding: 0.3rem 0.55rem;
    opacity: 0.95;
    transition: opacity 0.2s, transform 0.2s;
  }
  .brand-wordmark {
    font-family: 'DM Serif Display', serif;
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    color: #fff;
  }
  .brand-wordmark em {
    font-style: italic;
    color: var(--gold);
    font-weight: 700;
  }
  .nav-brand:hover .logo-humboldt { opacity: 1; transform: scale(1.03); }
  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }
  .nav-links a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: #fff; }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }
  .lang-selector { display: flex; align-items: center; gap: 0.3rem; }
  .lang-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.45);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    cursor: pointer;
    padding: 0.15rem 0.3rem;
    border-radius: 2px;
    transition: color 0.2s;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .lang-btn:hover { color: rgba(255,255,255,0.85); }
  .lang-btn.active { color: var(--gold); }
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    width: 28px;
  }
  .nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: rgba(255,255,255,0.85);
    border-radius: 1px;
    transition: all 0.3s;
    transform-origin: center;
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu */
  .mobile-menu {
    background: var(--navy);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 1.5rem 2.5rem 2rem;
  }
  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-bottom: 1.5rem;
  }
  .mobile-menu ul a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.2s;
  }
  .mobile-menu ul a:hover { color: #fff; }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .nav-toggle { display: flex; }
    .nav-right > .lang-selector { display: none; }
    .nav-inner { padding: 0 1.5rem; }
  }
  @media (max-width: 480px) {
    .logo-humboldt { height: 28px; }
    .brand-wordmark { font-size: 0.92rem; }
  }
</style>

